# Path absoluto al volumen persistente (Railway lo monta en /app/data).
# Para Docker local también funciona porque WORKDIR=/app dentro del container.
DATABASE_URL=/app/data/bridge.db

# DLP: archivo de log de hits. Se dispara cuando un agente trusted manda a uno untrusted.
DLP_LOG_PATH=/app/data/dlp.log

# DLP patterns (opcional). Lista JSON de pares [regex, label].
# Ejemplo: DLP_PATTERNS_JSON=[["\\bsecret\\b","secret keyword"],["\\bapikey\\b","apikey keyword"]]
DLP_PATTERNS_JSON=

# Token requerido para POST /v1/agents/register.
# Si está vacío, el registro queda ABIERTO (cualquiera puede registrarse).
# Recomendado en producción: setear un token random largo y compartirlo solo
# con quien deba registrar agentes.
REGISTRATION_TOKEN=

# Token para endpoints administrativos (PATCH /v1/agents/{id}: marcar trusted,
# revocar, rotar key). Si está vacío, esos endpoints devuelven 503.
ADMIN_TOKEN=

# CORS allowed origins (coma-separados). Default "*". Para restringir:
# CORS_ORIGINS=https://tudominio.com,https://otrodominio.com
CORS_ORIGINS=*
